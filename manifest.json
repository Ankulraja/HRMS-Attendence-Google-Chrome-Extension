{
  "manifest_version": 3,
  "name": "HRMS Auto Login",
  "version": "0.3.0",
  "description": "Automatically logs into the Savvy HRMS portal using saved credentials.",
  "permissions": [
    "storage",
    "alarms",
    "notifications"
  ],
  "host_permissions": [
    "*://*.savvyhrms.in/*",
    "*://*.savvyhrms.co.in/*",
    "https://accounts.google.com/*"
  ],
  "icons": {
    "16": "logo.png",
    "48": "logo.png",
    "128": "logo.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "logo.png",
      "48": "logo.png",
      "128": "logo.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.savvyhrms.in/*",
        "*://*.savvyhrms.co.in/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_end"
    },
    {
      "matches": [
        "https://accounts.google.com/*"
      ],
      "js": [
        "google_content.js"
      ],
      "run_at": "document_end"
    }
  ]
}
